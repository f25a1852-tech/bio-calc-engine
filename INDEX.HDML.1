<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bio-Calc Engine: Probiotic Fermentation Kinetics</title>
    <!-- Tailwind CSS for sleek UI styling -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Chart.js for smooth mathematical animations -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- MathJax for rendering publication-quality LaTeX math formulas -->
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .font-mono { font-family: 'JetBrains Mono', monospace; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col justify-between">

    <!-- Top Navigation Bar & Meta Information -->
    <header class="bg-gradient-to-r from-teal-700 to-cyan-700 text-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <span class="bg-teal-500/30 text-teal-200 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                    SFP: Agro Product Technology
                </span>
                <h1 class="text-2xl md:text-3xl font-extrabold mt-1 tracking-tight">Bio-Calc Engine</h1>
                <p class="text-teal-100 text-xs md:text-sm mt-0.5">Tracking Instantaneous Biomass Growth Rate of Probiotic Cultures in Fermented Coconut Milk Products</p>
            </div>
            <div class="text-sm bg-black/10 px-4 py-2 rounded-xl backdrop-blur-md border border-white/10 self-start md:self-center">
                <span class="block text-cyan-200 text-[10px] font-bold uppercase tracking-wider">Operational Mode</span>
                <strong class="font-semibold text-white">Interactive Bioscience Sandbox</strong>
            </div>
        </div>
    </header>

    <!-- Main Workspace Container -->
    <main class="max-w-7xl mx-auto px-4 py-8 grid grid-cols-1 lg:grid-cols-12 gap-8 flex-grow w-full">
        
        <!-- Left Workspace: Scientific Blueprint & Formula Sheets (5 Columns) -->
        <section class="lg:col-span-5 flex flex-col gap-6">
            
            <!-- Problem Definition Panel -->
            <div class="bg-white p-6 rounded-2xl shadow-xs border border-slate-200">
                <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2 mb-3">
                    <span class="p-1.5 bg-teal-100 text-teal-700 rounded-lg text-sm">🧪</span> 
                    The Agro-Product Scenario
                </h2>
                <p class="text-slate-600 text-sm leading-relaxed mb-4">
                    During the industrial fermentation of plant-based dairy substitutes like Malaysian coconut milk (<em>santan</em>) yogurt, monitoring probiotic biomass concentration is critical. Over-fermentation leads to structural separation and extreme acidity, while under-fermentation yields low probiotic efficacy. 
                </p>
                <div class="p-3.5 bg-amber-50 border-l-4 border-amber-500 rounded-r-xl text-xs text-amber-900 leading-relaxed">
                    <strong class="font-bold block mb-1 text-amber-950">Industrial Grounding & Citations:</strong>
                    Growth profile modeling configurations mirror standard bacterial phase transitions recorded in the <strong>Malaysian Journal of Microbiology (MJM)</strong> and microbial kinetics portals on <strong>ScienceDirect</strong>. The culture follows a standard sigmoidal pattern over a tight 24-hour manufacturing window.
                </div>
            </div>

            <!-- Mathematical Modeling Panel -->
            <div class="bg-white p-6 rounded-2xl shadow-xs border border-slate-200">
                <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2 mb-4">
                    <span class="p-1.5 bg-blue-100 text-blue-700 rounded-lg text-sm">📊</span> 
                    Kinetics Calculus Framework
                </h2>
                
                <!-- Function f(x) Description -->
                <div class="mb-5 pb-4 border-b border-slate-100">
                    <span class="text-[11px] font-bold tracking-wider text-slate-400 uppercase block mb-1">Biomass Growth Model $f(x)$</span>
                    <div class="bg-slate-50 p-3 rounded-xl overflow-x-auto text-center my-2 text-slate-900">
                        $$f(x) = \frac{L}{1 + e^{-k(x - x_0)}}$$
                    </div>
                    <p class="text-xs text-slate-500 leading-relaxed mt-1">
                        Predicts total cumulative probiotic biomass density ($g/L$) at fermentation hour $x$. Maximum carrying capacity $L = 12.0\text{ g/L}$, growth steepness index $k = 0.35$, and midpoint axis $x_0 = 10\text{ hours}$.
                    </p>
                </div>

                <!-- Derivative f'(x) Description -->
                <div>
                    <span class="text-[11px] font-bold tracking-wider text-slate-400 uppercase block mb-1">Instantaneous Growth Speed $f'(x)$</span>
                    <div class="bg-slate-50 p-3 rounded-xl overflow-x-auto text-center my-2 text-slate-900">
                        $$f'(x) = \frac{L \cdot k \cdot e^{-k(x - x_0)}}{(1 + e^{-k(x - x_0)})^2}$$
                    </div>
                    <p class="text-xs text-slate-500 leading-relaxed mt-1">
                        Derived using the Quotient and Chain Rules. This gives the <strong>exact instantaneous rate of change</strong> ($g/L\text{ per hour}$) at any specific timestamp, removing guessing games from batch run operations.
                    </p>
                </div>
            </div>
        </section>

        <!-- Right Workspace: Interactive Graphic Rendering Engine (7 Columns) -->
        <section class="lg:col-span-7 flex flex-col gap-6">
            
            <!-- Graphic Interface Canvas -->
            <div class="bg-white p-6 rounded-2xl shadow-xs border border-slate-200 flex-grow flex flex-col justify-between">
                <div>
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-4">
                        <div>
                            <h2 class="text-lg font-bold text-slate-900">Fermentation Kinetics Processing Curve</h2>
                            <p class="text-xs text-slate-500">Isolate precise micro-rates by clicking directly on the plot coordinate nodes</p>
                        </div>
                        <span class="self-start sm:self-center bg-cyan-50 text-cyan-700 border border-cyan-200 text-xs font-semibold px-2.5 py-1 rounded-md font-mono">
                            Chart.js v4.4 Engine
                        </span>
                    </div>
                    
                    <!-- Dynamic Responsive Canvas Wrapper -->
                    <div class="relative w-full h-[320px] md:h-[360px]">
                        <canvas id="fermentationChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Real-time Mathematical Output Console -->
            <div id="analyticsConsole" class="bg-slate-950 text-slate-100 p-6 rounded-2xl shadow-xl border border-slate-800 transition-all duration-200">
                <div class="flex items-center justify-between mb-4 border-b border-slate-800 pb-3">
                    <span class="text-xs font-mono font-bold tracking-widest text-cyan-400 uppercase flex items-center gap-2">
                        <span class="h-2 w-2 rounded-full bg-cyan-400 animate-pulse"></span>
                        Micro-Calculus Analytical Readout
                    </span>
                    <span class="text-[10px] text-slate-500 font-mono">DERIVATIVE_MODULE_ACTIVE</span>
                </div>
                
                <!-- Initial State Text Box -->
                <div id="promptBox" class="text-center py-6">
                    <p class="text-sm text-slate-400 font-medium">💡 Interactive Prompt: Click on any plot point on the graph above to compute the first derivative and output the biological translation.</p>
                </div>

                <!-- Live Mathematical Calculation Output Structure (Hidden on load) -->
                <div id="resultsStructure" class="hidden grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="space-y-3 font-mono border-r border-slate-800/60 pr-2">
                        <div>
                            <span class="text-[10px] text-slate-500 block uppercase font-bold">Fermentation Timeline Point (x)</span>
                            <span id="labelHour" class="text-lg font-bold text-white font-sans">--</span>
                        </div>
                        <div>
                            <span class="text-[10px] text-slate-500 block uppercase font-bold">Biomass Concentration f(x)</span>
                            <span id="labelBiomass" class="text-lg font-bold text-cyan-400 font-sans">--</span>
                        </div>
                        <div>
                            <span class="text-[10px] text-slate-500 block uppercase font-bold">Instantaneous Growth Rate f'(x)</span>
                            <span id="labelRate" class="text-lg font-bold text-emerald-400 font-sans">--</span>
                        </div>
                    </div>
                    <div class="bg-slate-900 p-4 rounded-xl border border-slate-800 flex flex-col justify-center">
                        <span class="text-[10px] font-bold text-amber-400 uppercase tracking-wider block mb-1.5 font-mono">✦ Biological Translation</span>
                        <p id="labelExplanation" class="text-xs text-slate-300 leading-relaxed font-sans">Click a node coordinates to extract agro-product insights.</p>
                    </div>
                </div>
            </div>

        </section>
    </main>

    <!-- Footer Area and Industry Disclaimers -->
    <footer class="bg-slate-950 text-slate-500 text-xs border-t border-slate-900 py-6 mt-12">
        <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-start justify-between gap-4">
            <div>
                <p class="font-semibold text-slate-400">SFP: Agro Product Technology Interactive Module</p>
                <p class="mt-1 text-slate-600">Built with HTML5, Tailwind CSS, Chart.js, and MathJax Rendering Infrastructure.</p>
            </div>
            <div class="text-slate-600 max-w-lg leading-relaxed">
                <span class="block font-bold text-[10px] text-slate-500 uppercase tracking-wider mb-0.5 font-mono">Bioscience Validation Dossier</span>
                Sigmoidal equations and numerical constants match kinetic profiles for alternative plant-milk substrates detailed across industrial biotechnology platforms including the Malaysian Journal of Microbiology (MJM) and the ScienceDirect Food Bioprocess Engineering repository.
            </div>
        </div>
    </footer>

    <!-- Calculus Calculation and Graphics Control Script -->
    <script>
        // Set standard logistic kinetics modeling constraints
        const L = 12.0;    // Theoretical Max Carrying Capacity in g/L
        const k = 0.35;   // Specific Growth Acceleration Multiplier
        const x0 = 10;    // Inflection point marker (Hours elapsed to reach peak efficiency)

        // Standard Logistic Equation Matrix: f(x)
        function calculateBiomass(x) {
            return L / (1 + Math.exp(-k * (x - x0)));
        }

        // Exact Analytical First Derivative Matrix: f'(x)
        function calculateDerivative(x) {
            const exponentialTerm = Math.exp(-k * (x - x0));
            return (L * k * exponentialTerm) / Math.pow(1 + exponentialTerm, 2);
        }

        // Construct 24-Hour Dataset Collections
        const hoursAxis = [];
        const biomassDataset = [];
        const derivativeDataset = [];

        for (let hour = 0; hour <= 24; hour++) {
            hoursAxis.push(hour);
            biomassDataset.push(calculateBiomass(hour).toFixed(2));
            derivativeDataset.push(calculateDerivative(hour).toFixed(2));
        }

        // Canvas Rendering Setup via Chart.js Architecture
        const chartElement = document.getElementById('fermentationChart').getContext('2d');
        
        const fermentationChart = new Chart(chartElement, {
            type: 'line',
            data: {
                labels: hoursAxis,
                datasets: [
                    {
                        label: 'Total Probiotic Biomass f(x) (g/L)',
                        data: biomassDataset,
                        borderColor: '#0f766e', // Teal 700
                        backgroundColor: 'rgba(15, 118, 110, 0.04)',
                        borderWidth: 3.5,
                        pointBackgroundColor: '#0f766e',
                        pointHoverRadius: 9,
                        pointHoverBackgroundColor: '#2563eb', // Active Blue hover highlight
                        fill: true,
                        tension: 0.15,
                        yAxisID: 'yBiomassAxis'
                    },
                    {
                        label: "Instantaneous Growth Rate f'(x) (g/L/hour)",
                        data: derivativeDataset,
                        borderColor: '#0284c7', // Sky 600
                        borderDash: [6, 4],
                        borderWidth: 2,
                        pointRadius: 0, // Keeps line sleek unless selected
                        fill: false,
                        tension: 0.15,
                        yAxisID: 'yRateAxis'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                        labels: {
                            font: { family: 'Plus Jakarta Sans', size: 11, weight: '500' },
                            boxWidth: 14,
                            padding: 15
                        }
                    },
                    tooltip: {
                        mode: 'index',
                        intersect: false
                    }
                },
                scales: {
                    x: {
                        title: {
                            display: true,
                            text: 'Fermentation Duration Timeline (Hours)',
                            font: { family: 'Plus Jakarta Sans', weight: '700', size: 12 }
                        },
                        grid: { color: 'rgba(0, 0, 0, 0.02)' }
                    },
                    yBiomassAxis: {
                        type: 'linear',
                        display: true,
                        position: 'left',
                        title: {
                            display: true,
                            text: 'Accumulated Biomass Density (g/L)',
                            font: { family: 'Plus Jakarta Sans', weight: '700', size: 12 }
                        },
                        min: 0,
                        max: 14,
                        grid: { color: 'rgba(0, 0, 0, 0.04)' }
                    },
                    yRateAxis: {
                        type: 'linear',
                        display: true,
                        position: 'right',
                        title: {
                            display: true,
                            text: 'Growth Velocity Rate (g/L/hour)',
                            font: { family: 'Plus Jakarta Sans', weight: '700', size: 12 }
                        },
                        min: 0,
                        max: 1.5,
                        grid: { drawOnChartArea: false } // Prevents dual-grid visual collision
                    }
                },
                // Intercept mouse clicks to calculate precise derivative output
                onClick: (event, chartElements) => {
                    if (chartElements.length > 0) {
                        const structuralIndex = chartElements[0].index;
                        const targetHour = hoursAxis[structuralIndex];
                        executeMicroCalculusCalculations(targetHour);
                    }
                }
            }
        });

        // Numerical Engine mapping derivatives to practical food-processing insights
        function executeMicroCalculusCalculations(selectedHour) {
            const activeBiomass = calculateBiomass(selectedHour);
            const activeRate = calculateDerivative(selectedHour);
            
            let biologicalInsightText = "";

            // Evaluate biological process phase based on derivative thresholds
            if (selectedHour <= 4) {
                biologicalInsightText = `Hour ${selectedHour} represents the initial Lag Phase. The derivative value is extremely low (${activeRate.toFixed(2)} g/L/hr) because the bacteria are adjusting to the fatty acid environment of the coconut milk. Minimal production happening.`;
            } else if (selectedHour > 4 && selectedHour < 10) {
                biologicalInsightText = `Between Hours 5 and 9, the first derivative is growing exponentially. The probiotics are dividing rapidly, breaking down coconut carbohydrates into organic acids. Production speed is accelerating.`;
            } else if (selectedHour === 10) {
                biologicalInsightText = `Hour 10 is the critical Inflection Point! The first derivative is at its maximum absolute peak (${activeRate.toFixed(2)} g/L/hr). This is the absolute fastest transformation speed. Excellent point for assessing product quality parameters.`;
            } else if (selectedHour > 10 && selectedHour <= 16) {
                biologicalInsightText = `Past Hour 10, the growth rate (derivative) is actively decelerating. Total biomass is still increasing, but the speed is tapering off as primary nutrients in the santan are consumed and acidity builds up.`;
            } else {
                biologicalInsightText = `At Hour ${selectedHour}, the derivative converges closely toward zero. The batch has reached the Stationary Phase. Growth has locked up due to resource exhaustion. The yogurt must be chilled now to secure maximum shelf life stability.`;
            }

            // Manipulate DOM elements to swap visibility state
            document.getElementById('promptBox').classList.add('hidden');
            document.getElementById('resultsStructure').classList.remove('hidden');
            
            // Brief visual ping notification transformation on console box
            const UIConsole = document.getElementById('analyticsConsole');
            UIConsole.classList.add('ring-2', 'ring-cyan-500');
            setTimeout(() => UIConsole.classList.remove('ring-2', 'ring-cyan-500'), 300);

            // Populate calculations directly into target nodes
            document.getElementById('labelHour').innerText = `Hour ${selectedHour}.00`;
            document.getElementById('labelBiomass').innerText = `${activeBiomass.toFixed(2)} g/L`;
            document.getElementById('labelRate').innerText = `${activeRate.toFixed(2)} g/L / hour`;
            document.getElementById('labelExplanation').innerText = biologicalInsightText;
        }
    </script>
</body>
</html>
